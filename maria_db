GRANT ALL PRIVILEGES ON teammaster_db.* TO 'teammaster_user'@'localhost';
FLUSH PRIVILEGES;

-- 3. Seleccionar la base de datos y crear la tabla
USE teammaster_db;

CREATE TABLE pagos (
    id INT AUTO_INCREMENT PRIMARY KEY,
    id_acudiente VARCHAR(50) NOT NULL,
    monto DECIMAL(10,2) NOT NULL,
    concepto VARCHAR(100) NOT NULL,
    estado VARCHAR(20) NOT NULL,
    comprobante VARCHAR(50) NOT NULL,
    fecha TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

